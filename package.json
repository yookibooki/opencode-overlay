{
  "name": "opencode-thrifty",
  "version": "0.0.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "bun run scripts/clean.mjs",
    "build": "bun run scripts/build.mjs",
    "check": "bun run check:src && bun run check:scripts",
    "check:src": "tsc --noEmit -p tsconfig.json",
    "check:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun run scripts/test.mjs",
    "snapshots:update": "bun scripts/update-snapshots.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "keywords": [
    "opencode",
    "opencode-plugin"
  ],
  "license": "MIT",
  "description": "OpenCode prompt and tool description overrides",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
