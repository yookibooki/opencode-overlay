{
  "name": "opencode-overlay",
  "version": "0.0.8",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "bun run scripts/clean.mjs",
    "build": "bun run scripts/build.mjs",
    "check": "bun run check:src && bun run check:scripts",
    "check:src": "tsc --noEmit -p tsconfig.json",
    "check:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun run scripts/test.mjs",
    "snapshots:update": "bun scripts/update-snapshots.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "keywords": [
    "opencode",
    "opencode-plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yookibooki/opencode-overlay.git"
  },
  "homepage": "https://github.com/yookibooki/opencode-overlay#readme",
  "bugs": {
    "url": "https://github.com/yookibooki/opencode-overlay/issues"
  },
  "description": "OpenCode prompt and tool description overrides",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
